        </div>
        <div class="we-step">
          <div class="we-num orange">3</div>
          <div class="we-text">% Moisture = <code class="o">(0.071 / 1.512) × 100 = <strong>4.70%</strong></code></div>
        </div>
      </div>
    </div>

  </div>
</section>

